# Local environment template
# Copy to .env.local and fill values locally/hosting provider. Do not commit real secrets.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 media storage
# Public images should resolve under CLOUDFLARE_R2_PUBLIC_BASE_URL, e.g. https://images.dreigewinnt.com
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=dreigewinnt-media
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://images.dreigewinnt.com
